# Copy to /etc/systemd/system/vite-cms-admin.service (adjust User, paths).
# Same PATH rules as vite-main-web.service.example (node:path error = wrong Node on PATH).

[Unit]
Description=PGP cms-admin — Vite dev (port 5174)
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/pgp-main-web/cms-admin
Environment=NODE_ENV=development
Environment=PATH=/usr/bin:/bin
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0 --port 5174
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
