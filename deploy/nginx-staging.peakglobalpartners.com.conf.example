# TLS terminates here; Django upstream on 127.0.0.1:8000 (gunicorn).
# GitHub Actions rsync:
#   main_web/dist/*  → $root/
#   cms-admin/dist/* → $root/cms/
#
# URLs:
#   https://staging.peakglobalpartners.com/       → main_web
#   https://staging.peakglobalpartners.com/cms/  → cms-admin (built with VITE_BASE_PATH=/cms/)
#   https://staging.peakglobalpartners.com/api/    → Django
#   https://staging.peakglobalpartners.com/media/  → uploads

upstream django_staging {
    server 127.0.0.1:8000;
    keepalive 8;
}

server {
    listen 443 ssl http2;
    server_name staging.peakglobalpartners.com;

    # ssl_certificate     /etc/letsencrypt/live/staging.peakglobalpartners.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/staging.peakglobalpartners.com/privkey.pem;

    root /var/www/staging.peakglobalpartners.com;
    index index.html;

    client_max_body_size 25M;

    location /api/ {
        proxy_pass http://django_staging;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /media/ {
        alias /path/to/pgp-main-web/backend/media/;
    }

    location = /cms {
        return 301 /cms/;
    }

    location /cms/ {
        try_files $uri $uri/ /cms/index.html;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    server_name staging.peakglobalpartners.com;
    return 301 https://$host$request_uri;
}
