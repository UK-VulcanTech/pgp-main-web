# Copy to .env on the server (or locally). Never commit .env.
# Manual VPS + Vite dev: VPS_MANUAL_DEPLOY.md

# API origin, no trailing slash. Empty = same browser origin (/api/... via nginx or Vite proxy).
# VITE_API_BASE=https://staging.peakglobalpartners.com
VITE_API_BASE=

# Subpath when served at https://your-domain/cms/ (must end with /). Direct port 5174 only: use /
VITE_BASE_PATH=/cms/

# Vite dev: proxy /api → Django
VITE_PROXY_API=http://127.0.0.1:8000
