# Copy to .env for local dev. Never commit .env.
# Staging/production CI: see GITHUB_STAGING_ENV.md

# API origin (no trailing slash). Empty = same origin; local dev uses Vite proxy to :8000.
# VITE_API_BASE=https://staging.peakglobalpartners.com

# Subpath on shared domain (must end with /). Local dev: use / or omit.
# VITE_BASE_PATH=/cms/
