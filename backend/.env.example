# Copy to .env and fill in. Never commit .env.
# GitHub / VPS staging: GITHUB_STAGING_ENV.md and ENVIRONMENT.md

DEBUG=True

# Required in production. Generate a real one:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-long-random-string-in-production

# Comma-separated hostnames (no spaces). Production example:
# ALLOWED_HOSTS=api.yourdomain.com,.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Required when DEBUG=False. Full URLs with scheme, no trailing slash, comma-separated:
# CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://cms.yourdomain.com
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# PostgreSQL (django-environ), URL-encode special characters in password:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# SQLite (local):
# DATABASE_URL=sqlite:///db.sqlite3
DATABASE_URL=

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Production (behind HTTPS reverse proxy)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
