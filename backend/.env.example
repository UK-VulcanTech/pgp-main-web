# Copy to .env on the server only. Never commit .env.
# Full manual deploy: VPS_MANUAL_DEPLOY.md

# Local development
DEBUG=True
SECRET_KEY=replace-with-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
DATABASE_URL=sqlite:///db.sqlite3

# --- Example: staging on VPS (adjust paths and domain) ---
# DEBUG=False
# SECRET_KEY=<output of: python -c "import secrets; print(secrets.token_urlsafe(50))">
# ALLOWED_HOSTS=staging.peakglobalpartners.com,localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=https://staging.peakglobalpartners.com
# DATABASE_URL=sqlite:////home/deploy/pgp-main-web/backend/db.sqlite3

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Behind HTTPS reverse proxy (use True on staging/production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
