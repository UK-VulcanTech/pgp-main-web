# Copy to .env for local dev. Never commit .env.
# GitHub Actions variable: MAIN_WEB_VITE_PUBLIC_API_URL (see ENVIRONMENT.md).

# Public API origin, no trailing slash. Empty = browser uses same origin + /api/public/v1.
# Production-style example:
# VITE_PUBLIC_API_URL=https://api.yourdomain.com
# VITE_PUBLIC_API_URL=

# Vite dev server only — proxy /api to Django (not used in production build):
VITE_PROXY_API=http://127.0.0.1:8000
