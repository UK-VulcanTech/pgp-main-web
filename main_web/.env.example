# Copy to .env on the server (or locally). Never commit .env.
# Manual VPS + Vite dev: VPS_MANUAL_DEPLOY.md

# Public API origin, no trailing slash. Leave empty when nginx serves /api on the same host.
# VITE_PUBLIC_API_URL=https://staging.peakglobalpartners.com
VITE_PUBLIC_API_URL=

# Vite dev server: proxy /api → Django (Gunicorn on the same machine)
VITE_PROXY_API=http://127.0.0.1:8000
